# ════════════════════════════════════════════════════════
# PhantomBox .env  — add these lines to your existing .env
# ════════════════════════════════════════════════════════

# System Secret for AES Key Derivation
SYSTEM_SECRET=your_super_secure_random_secret_key_here_1234567890_change_me

# PhantomNet Blockchain Nodes
GENESIS_NODE=http://127.0.0.1:5001
PEER_NODE=http://127.0.0.1:5002
PHANTOMBOX_URL=http://127.0.0.1:8000

# Storage Nodes
NOISE_NODES=http://127.0.0.1:9001,http://127.0.0.1:9002

# Ports
BLOCKCHAIN_PORT=5001
PEER_PORT=5002
PHANTOMBOX_PORT=8000
NOISE_NODE_PORTS=9001,9002

# Security
AUTHORITY_KEYS=node1_key,node2_key
FRAGMENT_COUNT=3
MIN_FRAGMENTS=2

# ── NEW: MySQL Database ──────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=Sachhu55@#
DB_NAME=phantombox_db

# ── NEW: JWT Secret ──────────────────────────────────────
# Change this to a long random string in production!
JWT_SECRET=phantombox_jwt_secret_change_in_production_2024

# ── NEW: Admin Registration Secret ───────────────────────
# Users must enter this key when selecting "Admin" role at signup
ADMIN_SECRET_KEY=phantom_admin_secret_2024

# ── NEW: JWT Token TTL ────────────────────────────────────
ACCESS_TOKEN_TTL=86400     # 24 hours (seconds)
REFRESH_TOKEN_TTL=604800   # 7 days

# App Settings
MAX_FILE_SIZE=10485760     # 10MB
DEBUG_MODE=True